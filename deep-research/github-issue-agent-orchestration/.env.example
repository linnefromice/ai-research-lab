# このプロジェクトが操作する GitHub リポジトリ (owner/repo)
# 例: TARGET_REPO=linnefromice/agent-orch-sandbox
TARGET_REPO=

# /orchestrate-once 1 周あたりに処理する issue 上限 (既定 1)
MAX_ISSUES_PER_RUN=1

# [3] impl issue の担当エージェント。breakdown-design が起票時の agent: ラベルを
# これで決める。Step 1 (Claude 単独) は claude、Codex 導入後 (Step 2) は codex。
IMPL_AGENT=claude

# [3] 実装に使う TARGET_REPO のローカル clone のパス (絶対パス)
LOCAL_CLONE=

# 上記 clone から切る worktree の親ディレクトリ (絶対パス)
WORKTREE_BASE=
